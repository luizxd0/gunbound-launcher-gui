[URLs]
# News/notice shown in the launcher panel (local file or http(s) URL). If omitted, uses notice.html in the launcher folder.
Notice=.\notice.html
# Patch/update (used when version-check and patching logic is implemented)
Manifest=http://update.gunbound.site/update/file-list.txt
BaseFiles=http://update.gunbound.site/update/gamefiles/
LauncherVersion=http://update.gunbound.site/update/launcher-version.txt

[LauncherConfig]
LastID=
BuddyIP=classic-gunbound.servegame.com
ServerIP=classic-gunbound.servegame.com
BaseUrl=http://classic-gunbound.servegame.com
# Optional: force Caps Lock off just before launching the game (1=on, 0=off)
# ForceCapsLockOff=1
# Optional: URL to verify username/password before starting the game. Launcher POSTs username and password (form-encoded). 200 = OK, 401 = invalid. If omitted, the launcher does not verify and starts the game immediately.
# LoginCheckUrl=http://classic-gunbound.servegame.com/api/login-check

[Screen]
# Player-facing display setting:
# - fullscreen_voodoo2 (default/recommended fullscreen profile)
# - fullscreen (native)
# - windowed
# Legacy aliases (1/2/4, voodoo2/dxwnd/compat/compact) are mapped to fullscreen_voodoo2.
DisplayProfile=fullscreen_voodoo2
# Profile folders (copied to game folder before launch):
# compat\3 or compat\windowed           -> windowed
# compat\1 or compat\fullscreen_voodoo2 -> fullscreen voodoo2
# Advanced internal options exist but are intentionally hidden from players.
# Windowed mode uses a fixed DxWnd proxy launch path for stability.
# Optional hidden tuning: set to 0 only if a specific client requires hook-all-dlls.
# DxwndDisableHookDlls=1

[GameConfig]
Effect3D=3
VolEffect=95
VolMusic=94
BackGround=1
GraphResolution=0
